# Copy to .env and fill in the blanks. Never commit .env.

# --- runtime ---
ENV=dev
LOG_LEVEL=debug

# --- http ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- postgres (docker compose; host port 55432 to avoid clash with system postgres) ---
DATABASE_URL=postgres://fintrack:fintrack@localhost:55432/fintrack?sslmode=disable

# --- auth ---
# Local dev: any random string works. Generate with: openssl rand -hex 32
# Production (Supabase): set to your Supabase project JWT secret.
JWT_SECRET=replace-me-openssl-rand-hex-32
JWT_ISSUER=fintrack-local
# Phase 0 local-first auth: enables PUBLIC POST /v1/auth/register + /v1/auth/login
# (no passwords — they mint the same HS256 JWT the API validates).
# Set to false in production once Supabase Auth takes over.
AUTH_LOCAL_ENABLED=true

# --- encryption ---
# AES-256 key for the income field. EXACTLY 32 bytes when hex-decoded.
# Generate with: openssl rand -hex 32
INCOME_ENCRYPTION_KEY=replace-me-openssl-rand-hex-32

# --- object storage (minio local) ---
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=fintrack
STORAGE_SECRET_KEY=fintrack-dev-secret
STORAGE_BUCKET=receipts
STORAGE_USE_SSL=false

# --- anthropic (receipt photo categorization) ---
# Leave blank to fall back to the stub analyzer (no real Claude calls).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- openrouter (financial planner chat — language layer only) ---
# The planner's budget math is deterministic; OpenRouter only handles intent +
# narration. Leave blank to fall back to the deterministic stub (no network).
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_MODEL=nousresearch/hermes-3-llama-3.1-405b
